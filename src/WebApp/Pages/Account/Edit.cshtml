@page
@using AirWeb.WebApp.Pages.Shared.EditorTemplates
@model EditModel
@{
    ViewData["Title"] = "Edit Your Profile";
    ViewData["NoAnchors"] = "True";
}

<h1>@ViewData["Title"]</h1>
<hr />

<h2>@Model.DisplayStaff.Name</h2>

<div class="p-3 border rounded-3 bg-light-subtle mb-3">
    <form method="post">
        <div class="row">
            <div class="col-lg mb-3">
                @Html.EditorFor(m => m.DisplayStaff.Email, EditorTemplate.InputDisabled)
            </div>
            <div class="col-md mb-3">
                @Html.EditorFor(m => m.UpdateStaff.PhoneNumber, EditorTemplate.Input)
            </div>
            <div class="col-md mb-3">
                @Html.EditorFor(m => m.UpdateStaff.OfficeId, EditorTemplate.Select, additionalViewData: new { Items = Model.OfficeSelectList })
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Theme</label>

            <div class="btn-group" role="group" aria-label="Theme selection">
                <input type="radio" class="btn-check" name="Theme" id="themeLight" value="light">
                <label class="btn btn-outline-secondary" for="themeLight">
                    Light
                </label>

                <input type="radio" class="btn-check" name="Theme" id="themeDark" value="dark">
                <label class="btn btn-outline-secondary" for="themeDark">
                    Dark
                </label>

                <input type="radio" class="btn-check" name="Theme" id="themeAuto" value="auto">
                <label class="btn btn-outline-secondary" for="themeAuto">
                    Auto
                </label>
            </div>
        </div>
        <partial name="Shared/_SubmitCancelButtons" />
    </form>

</div>
