@page "{id:int?}"
@using AirWeb.WebApp.Pages.Shared
@using AirWeb.WebApp.Pages.Shared.DisplayTemplates
@model LinkedEventsModel

@{
    ViewData["Title"] = $"Compliance Event Linking: Enforcement Case #{Model.Id}";
    ViewData["NoAnchors"] = "True";
}

<p class="d-print-none">
    <a asp-page="Details" asp-route-id="@Model.Id" class="lead icon-link">
        <partial name="Shared/_AppIconsPartial" model="@AppIcon.GoBack" />
        Back to Enforcement Case #@Model.Id
    </a>
</p>

<h1>Compliance Event Linking</h1>

<section class="mt-4">
    <h2 class="h4">Linked Discovery Events</h2>
    @if (!Model.LinkedComplianceEvents.Any())
    {
        <p class="border rounded-3 p-3 mt-3">
            <em>None.</em>
        </p>
    }
    else
    {
        <div class="table-responsive mb-3">
            <form method="post" asp-page-handler="UnlinkEvent">
                <table class="table table-hover mb-0 table-collapsible" aria-label="Compliance Events linked to the Enforcement Case">
                    <thead>
                    <tr>
                        <th scope="col" class="text-nowrap">Tracking #</th>
                        <th scope="col" class="text-nowrap">Work Type</th>
                        <th scope="col" class="text-nowrap">Event Date</th>
                        <th scope="col">Status</th>
                        <th scope="col" class="text-center">Actions</th>
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var item in Model.LinkedComplianceEvents)
                    {
                        <tr>
                            <th data-label="Tracking #" scope="row">
                                <a asp-page="/Compliance/Work/Details" asp-route-id="@item.Id.ToString()"
                                   class="btn btn-sm btn-outline-primary ms-1 ms-md-0" target="_blank">
                                    @item.Id.ToString()
                                </a>
                            </th>
                            <td data-label="Work Type">@item.ComplianceWorkType.GetDisplayName()</td>
                            <td data-label="Event Date">
                                <span class="text-nowrap">@Html.DisplayFor(_ => item.EventDate, DisplayTemplate.ShortDateOnly)</span>
                                <span class="d-md-block">@item.EventDateName</span>
                            </td>
                            <td data-label="Status" class="text-nowrap">
                                @Html.DisplayFor(_ => item.IsClosed, DisplayTemplate.BoolClosed)
                                @if (item.IsClosed)
                                {
                                    <span class="d-md-block">@Html.DisplayFor(_ => item.ClosedDate, DisplayTemplate.ShortDateOnly)</span>
                                }
                            </td>
                            <td data-label="Actions" class="text-md-end">
                                <button type="submit" name="eventId" value="@item.Id.ToString()" class="btn btn-sm btn-outline-danger ms-1 ms-md-0"
                                        title="Unlink Event from Enforcement Case">🡳&nbsp;Unlink&nbsp;Event
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </form>
        </div>
    }
</section>

<section class="mt-4">
    <h2 class="h4">Available Compliance Events</h2>
    @if (!Model.AvailableComplianceEvents.Any())
    {
        <p class="border rounded-3 p-3 mt-3">
            <em>None.</em>
        </p>
    }
    else
    {
        <div class="table-responsive mb-3">
            <form method="post" asp-page-handler="LinkEvent">
                <table class="table table-hover mb-0 table-collapsible" aria-label="Compliance Events available to link">
                    <thead>
                    <tr>
                        <th scope="col" class="text-nowrap">Tracking #</th>
                        <th scope="col" class="text-nowrap">Work Type</th>
                        <th scope="col" class="text-nowrap">Event Date</th>
                        <th scope="col">Status</th>
                        <th scope="col" class="text-center">Actions</th>
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var item in Model.AvailableComplianceEvents)
                    {
                        <tr>
                            <th data-label="Tracking #" scope="row">
                                <a asp-page="/Compliance/Work/Details" asp-route-id="@item.Id.ToString()"
                                   class="btn btn-sm btn-outline-primary ms-1 ms-md-0" target="_blank">
                                    @item.Id.ToString()
                                </a>
                            </th>
                            <td data-label="Work Type" >@item.ComplianceWorkType.GetDisplayName()</td>
                            <td data-label="Event Date">
                                <span class="text-nowrap">@Html.DisplayFor(_ => item.EventDate, DisplayTemplate.ShortDateOnly)</span>
                                <span class="d-md-block">@item.EventDateName</span>
                            </td>
                            <td data-label="Status" class="text-nowrap">
                                @Html.DisplayFor(_ => item.IsClosed, DisplayTemplate.BoolClosed)
                                @if (item.IsClosed)
                                {
                                    <span class="d-md-block">@Html.DisplayFor(_ => item.ClosedDate, DisplayTemplate.ShortDateOnly)</span>
                                }
                            </td>
                            <td data-label="Actions" class="text-md-end">
                                <button type="submit" name="eventId" value="@item.Id.ToString()" class="btn btn-sm btn-outline-success ms-1 ms-md-0"
                                        title="Link Event to Enforcement Case">🡱&nbsp;Link&nbsp;Event
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </form>
        </div>
    }
</section>
