@using AirWeb.WebApp.Pages.Shared.DisplayTemplates
@model List<AirWeb.AppServices.Reports.ComplianceDto.WorkItems.AccPartial>

<h2 id="accs">Annual Compliance Certifications</h2>

@{
    if (Model is not { Count: > 0 })
    {
        <div class="fce-content">None.</div>
        return;
    }

    var firstItem = Model.FirstOrDefault()!;
}

<table aria-labelledby="accs">
    <thead>
    <tr>
        <th scope="col" class="no-wrap">@Html.DisplayNameFor(_ => firstItem.Id)</th>
        <th scope="col">@Html.DisplayNameFor(_ => firstItem.AccReportingYear)</th>
        <th scope="col">@Html.DisplayNameFor(_ => firstItem.ReceivedDate)</th>
        <th scope="col">@Html.DisplayNameFor(_ => firstItem.Reviewer)</th>
        <th scope="col">@Html.DisplayNameFor(_ => firstItem.DeviationsReported)</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var i in Model)
    {
        <tr>
            <th scope="row">@i.Id.ToString()</th>
            <td>@i.AccReportingYear.ToString()</td>
            <td>@Html.DisplayFor(_ => i.ReceivedDate, DisplayTemplate.LongDateOnly)</td>
            <td>@i.Reviewer.SortableFullName</td>
            <td>@Html.DisplayFor(_ => i.DeviationsReported, DisplayTemplate.BoolYesNo)</td>
        </tr>
    }
    </tbody>
</table>
