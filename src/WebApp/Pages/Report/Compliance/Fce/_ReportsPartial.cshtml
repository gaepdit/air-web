@using AirWeb.WebApp.Pages.Shared.DisplayTemplates
@model List<AirWeb.AppServices.Reports.ComplianceDto.WorkItems.ReportPartial>

<h2 id="reports">Reports</h2>

@{
    if (Model is not { Count: > 0 })
    {
        <div class="fce-content">None.</div>
        return;
    }

    var firstItem = Model.FirstOrDefault()!;
}

<table aria-labelledby="reports">
    <thead>
    <tr>
        <th scope="col" class="no-wrap">@Html.DisplayNameFor(m => firstItem.Id)</th>
        <th scope="col">@Html.DisplayNameFor(m => firstItem.ReportPeriod)</th>
        <th scope="col">@Html.DisplayNameFor(m => firstItem.ReceivedDate)</th>
        <th scope="col">@Html.DisplayNameFor(m => firstItem.Reviewer)</th>
        <th scope="col">@Html.DisplayNameFor(m => firstItem.DeviationsReported)</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var i in Model)
    {
        <tr>
            <th scope="row" rowspan="2">
                <p>@i.Id</p>
            </th>
            <td>
                @i.ReportPeriod<br />
                @Html.DisplayFor(_ => i.ReportPeriodDateRange, new { Connector = "–" })
            </td>
            <td>@Html.DisplayFor(_ => i.ReceivedDate, DisplayTemplate.LongDateOnly)</td>
            <td>@i.Reviewer.SortableFullName</td>
            <td>@Html.DisplayFor(_ => i.DeviationsReported, DisplayTemplate.BoolYesNo)</td>
        </tr>
        <tr>
            <td colspan="4">
                <dl class="dl-inline">
                    <dt>@Html.DisplayNameFor(m => firstItem.Notes)</dt>
                    <dd>@i.Notes</dd>
                </dl>
            </td>
        </tr>
    }
    </tbody>
</table>
