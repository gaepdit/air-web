@using AirWeb.WebApp.Pages.Shared.DisplayTemplates
@model List<AirWeb.AppServices.Reports.ComplianceDto.WorkItems.EnforcementPartial>

<h2 id="enforcement-history">Five-Year History of Enforcement Actions</h2>

@{
    if (Model is not { Count: > 0 })
    {
        <div class="fce-content">None.</div>
        return;
    }

    var firstItem = Model.FirstOrDefault()!;
}

<table aria-labelledby="enforcement-history">
    <thead>
    <tr>
        <th scope="col" class="no-wrap">@Html.DisplayNameFor(_ => firstItem.Id)</th>
        <th scope="col">@Html.DisplayNameFor(_ => firstItem.StaffResponsible)</th>
        <th scope="col">@Html.DisplayNameFor(_ => firstItem.EnforcementDate)</th>
        <th scope="col">@Html.DisplayNameFor(_ => firstItem.EnforcementType)</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var i in Model)
    {
        <tr>
            <th scope="row">@i.Id</th>
            <td>@i.StaffResponsible.SortableFullName</td>
            <td>@Html.DisplayFor(_ => i.EnforcementDate, DisplayTemplate.LongDateOnly)</td>
            <td>@Html.DisplayFor(_ => i.EnforcementType, DisplayTemplate.TextOrPlaceholder)</td>
        </tr>
    }
    </tbody>
</table>
