@model AppIcon
@{
    var css = (string?)ViewData["CssClass"] ?? null;
    var icon = Model switch
    {
        AppIcon.AutoDarkMode => "circle-half",
        AppIcon.Badge => "person-badge",
        AppIcon.CheckIcon => "check-circle-fill",
        AppIcon.CheckMark => "check2",
        AppIcon.DarkMode => "moon-stars-fill",
        AppIcon.Download => "download",
        AppIcon.FindBy => "bookmark",
        AppIcon.GeoPin => "geo-alt",
        AppIcon.GoBack => "arrow-90deg-up",
        AppIcon.InfoIcon => "info-circle-fill",
        AppIcon.LightMode => "sun-fill",
        AppIcon.List => "list-ul",
        AppIcon.Map => "map",
        AppIcon.MapPin => "pin-map",
        AppIcon.People => "people-fill",
        AppIcon.Plus => "plus-lg",
        AppIcon.Print => "printer-fill",
        AppIcon.QuestionIcon => "question-circle",
        AppIcon.Refresh => "arrow-clockwise",
        AppIcon.Search => "search",
        AppIcon.Switch => "shuffle",
        AppIcon.Trash => "trash3",
        AppIcon.UpTop => "arrow-bar-up",
        AppIcon.WarningIcon => "exclamation-triangle-fill",
        _ => throw new ArgumentOutOfRangeException(nameof(Model)),
    };
}
<svg class="bi @css" role="img">
    <use href="@Url.Content("~/images/app-icons.svg?20260514")#@icon"></use>
</svg>
