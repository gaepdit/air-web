@using AirWeb.WebApp.Pages.Shared
<div class="print-toolbar">
    <button id="print-button" type="button" class="icon-link">
        <partial name="Shared/_AppIconsPartial" model="@AppIcon.Print" />
        Print
    </button>
    <button id="print-help-button" type="button" aria-details="tooltip-text">
        <partial name="Shared/_AppIconsPartial" model="@AppIcon.QuestionIcon" />
    </button>
    <div id="tooltip-text">
        <ul>
            <li>
                <strong>To save the file as PDF:</strong> Select the
                <kbd>
                    <partial name="Shared/_AppIconsPartial" model="@AppIcon.Print" />
                    Print</kbd>
                button and change the Printer/Destination option to “Save as PDF.”
            </li>
            <li>
                <strong>To hide the date/url headers and footers on the printout:</strong> Select the
                <kbd>
                    <partial name="Shared/_AppIconsPartial" model="@AppIcon.Print" />
                    Print</kbd>
                button, then select “More Settings.” Scroll to the bottom and <em>uncheck</em> “Headers and footers.”
            </li>
        </ul>
    </div>
</div>
