@page
@model SourceTestIndexModel
@{
    ViewData["Title"] = "Source Tests Needing Compliance Review";
}

<h1>@ViewData["Title"]</h1>
<div class="px-3 py-2 rounded-3 bg-light-subtle border mt-3 mb-4 d-md-inline-block">
    <form method="post" role="search" class="my-1">
        <div class="row row-cols-sm-auto align-items-center">
            <div class="col-12 mb-2 mb-sm-0">
                <label for="FindId">Find by Reference Number</label>
            </div>
            <div class="col-12">
                <div class="input-group input-group-sm">
                    <input id="FindId" asp-for="FindId" class="form-control" type="search" placeholder="Enter ID" aria-label="Search" />
                    <button class="btn btn-primary" type="submit">Open</button>
                </div>
            </div>
        </div>
        <div class="mt-2 mt-sm-0"><span asp-validation-for="FindId" class="text-danger-emphasis"></span></div>
    </form>
</div>

<div class="container">
    <div class="row">
        <div class="p-3 rounded-3 bg-light-subtle border col-lg-9">
            <div class="text-body-secondary pb-2"><em>All fields are optional.</em></div>
            <form method="get" asp-fragment="SearchResults">
                <h2 class="h4">Assignment</h2>
                <div class="row">
                    <div class="col-md mb-3">
                        <div class="form-floating">
                            <select asp-for="Office" asp-items="@Model.OfficesSelectList" class="form-select">
                                <option value="">@DefaultText.SelectOptionAny</option>
                            </select>
                            <label asp-for="Office" class="form-label"></label>
                        </div>
                    </div>
                    <div class="col-md">
                        <div class="form-floating">
                            <select asp-for="Staff" asp-items="@Model.StaffSelectList" class="form-select">
                                <option value="">@DefaultText.SelectOptionAny</option>
                            </select>
                            <label asp-for="Staff" class="form-label"></label>
                        </div>
                    </div>
                </div>

                <div>
                    <button id="SearchButton" type="submit" class="btn btn-lg btn-primary col-5 col-sm-4 col-lg-3 me-2 mt-3">Search</button>
                    <a asp-page="Index" class="btn btn-lg btn-outline-secondary col-4 col-sm-3 col-lg-3 me-2 mt-3">Clear Form</a>
                    <a asp-page="Index" asp-fragment="SearchResults" asp-route-Staff="@Model.UserId" class="btn btn-lg btn-outline-info col-5 col-sm-4 mt-3">Show Just Mine</a>
                </div>
            </form>
            <div class="lead mt-2">(Tests completed prior to January&nbsp;1,&nbsp;2023 are excluded.)</div>
        </div>
    </div>
</div>

<div id="SearchResults" class="mt-4">
    <h3>Search Results</h3>
</div>

@if (Model.SearchResults.TotalCount == 0)
{
    <p class="lead text-info">No matching source tests found.</p>
}
else
{
    <partial name="Shared/_PaginationNavAndCount" model="Model.ResultsDisplay" />
    <partial name="Shared/CompliancePartials/_SourceTestsTable" model="Model.SearchResults.Items" />
    <partial name="Shared/_PaginationNav" model="Model.ResultsDisplay" />
}

@section Scripts {
    <script src="~/js/formSearch.js"></script>
}
